<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:p="http://www.springframework.org/schema/p"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">
	
	<!-- Setter Injunction -->
	<bean id="employee1" class="com.coforge.model.Employee">
		<property name="eid" value="104"></property>
		<property name="ename" value="Valan"></property>
		<property name="esalary" value="2000"></property>
		<property name="dno" value="10"></property>
		<property name="address" ref="address1"></property>
		<property name="project" ref="project1"></property>
	</bean>
	
	<!-- Constructor Injunction -->
	<bean id="employee2" class="com.coforge.model.Employee">
		<constructor-arg name="eid" value="105"></constructor-arg>
		<constructor-arg name="ename" value="Raj"></constructor-arg>
		<constructor-arg name="esalary" value="3000"></constructor-arg>
		<constructor-arg name="dno" value="20"></constructor-arg>
		<constructor-arg name="address" ref="address2"></constructor-arg>
		<constructor-arg name="project" ref="project2"></constructor-arg>
	</bean>
	
	<bean id="address1" class = "com.coforge.model.Address">
		<property name="city" value="city-1"></property>
		<property name="state" value="state-1"></property>
	</bean>
	
	<bean id="address2" class = "com.coforge.model.Address">
		<constructor-arg name="city" value="city-2"></constructor-arg>
		<constructor-arg name="state" value="state-2"></constructor-arg>
	</bean>
	
	<bean id="project1" class = "com.coforge.model.Project">
		<property name="pid" value="117"></property>
		<property name="pname" value="Python"></property>
	</bean>
	
	<bean id="project2" class="com.coforge.model.Project">
		<constructor-arg name="pid" value="118"></constructor-arg>
		<constructor-arg name="pname" value="Java"></constructor-arg>
	</bean>
</beans>